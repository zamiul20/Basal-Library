<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Calculator.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Calculator"
    Title="Basal Calculator">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Calculator"
        ContentTemplate="{DataTemplate local:Calc_Page}"
        Route="Calc_Page" />
    <ShellContent
        Title="Convertor"
        ContentTemplate="{DataTemplate local:Convert_Page}"
        Route="Convert_Page" />

</Shell>
